# ─── Flask Backend — Required ──────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-random-secret-key-here

# The public URL where your Flask backend is deployed
BASE_URL=https://your-backend.up.railway.app

# The public URL where your Next.js frontend is deployed
FRONTEND_URL=https://your-frontend.up.railway.app

# ─── Docker Orchestration (v2) ─────────────────────────────────────────────────
# Name of the pre-built worker Docker image
WORKER_IMAGE=spb_worker:latest

# Host filesystem path to storage dir (mounted into worker containers)
# Set to the absolute path of ./storage/accounts on your server
HOST_STORAGE_PATH=/opt/spb/storage/accounts

# ─── Worker Node — Optional Proxy ──────────────────────────────────────────────
# Set a default proxy for all spawned workers (can be overridden per-account)
# Format: http://username:password@host:port
DEFAULT_PROXY_URL=
