# ─── Flask Backend — Required Environment Variables ───────────────────────────
# Generate a random secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-random-secret-key-here

# The public URL where your Flask backend is deployed on Railway
BASE_URL=https://your-backend.up.railway.app

# The public URL where your Next.js frontend is deployed on Railway
# Flask uses this for CORS and OAuth callback redirect
FRONTEND_URL=https://your-frontend.up.railway.app
